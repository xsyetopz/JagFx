<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:JagFX.Desktop.Controls"
             x:Class="JagFX.Desktop.Views.Rack.EnvelopeCell">

    <Border x:Name="CellBorder" BorderBrush="#272727" BorderThickness="0.5" Background="#111111" Margin="0.5">
        <DockPanel LastChildFill="True">
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="#1a1a1a"
                    Height="16" Padding="4,0">
                <TextBlock x:Name="TitleText"
                           FontSize="8" FontWeight="Bold"
                           Foreground="#686868"
                           VerticalAlignment="Center" />
            </Border>

            <!-- Canvas area -->
            <Panel x:Name="CanvasHost" Background="#0e0e0e">
                <!-- Populated dynamically based on CellType -->
                <controls:EnvelopeCanvas x:Name="EnvCanvas" IsVisible="False" />
                <controls:PoleZeroCanvas x:Name="PzCanvas" IsVisible="False" />
                <controls:WaveformCanvas x:Name="WaveCanvas" IsVisible="False" />
                <controls:FrequencyResponseCanvas x:Name="FreqCanvas" IsVisible="False" />
            </Panel>
        </DockPanel>
    </Border>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JagFx.Desktop.ViewModels"
             x:Class="JagFx.Desktop.Views.Header.HeaderBar"
             x:DataType="vm:MainViewModel"
             Height="40">

    <Border Background="{StaticResource SurfaceHeaderBrush}" BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="0,0,0,1" Padding="3,0">
        <StackPanel Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
            <!-- Patch Navigation -->
            <Button Theme="{StaticResource JagToolButton}"
                    Command="{Binding NavigatePatchCommand}"
                    CommandParameter="-1"
                    ToolTip.Tip="Previous patch">
                <PathIcon Data="{StaticResource IconChevronLeft}" Width="14" Height="14" />
            </Button>
            <Border Background="{StaticResource SurfaceInputBrush}" BorderBrush="{StaticResource BorderAccentBrush}"
                    BorderThickness="1" Padding="4,0" Width="100" Height="20"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding PatchName}"
                           Foreground="{StaticResource TextAccentBrush}"
                           FontWeight="Bold" FontSize="10"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Border>
            <Button Theme="{StaticResource JagToolButton}"
                    Command="{Binding NavigatePatchCommand}"
                    CommandParameter="1"
                    ToolTip.Tip="Next patch">
                <PathIcon Data="{StaticResource IconChevronRight}" Width="14" Height="14" />
            </Button>

            <!-- Separator -->
            <Border Width="1" Height="20" Background="{StaticResource BorderDefaultBrush}" Margin="2,0" />

            <!-- File Operations -->
            <Button Theme="{StaticResource JagToolButton}"
                    Command="{Binding OpenCommand}" ToolTip.Tip="Open file (Ctrl+O)">
                <PathIcon Data="{StaticResource IconFolderOpen}" Width="14" Height="14" />
            </Button>
            <Button Theme="{StaticResource JagToolButton}"
                    Command="{Binding SaveCommand}" ToolTip.Tip="Save file (Ctrl+S)">
                <PathIcon Data="{StaticResource IconContentSave}" Width="14" Height="14" />
            </Button>

            <!-- Separator -->
            <Border Width="1" Height="20" Background="{StaticResource BorderDefaultBrush}" Margin="2,0" />

            <!-- Transport -->
            <Button Theme="{StaticResource JagToolButton}"
                    Command="{Binding TogglePlayCommand}"
                    ToolTip.Tip="Play (Space)">
                <PathIcon Data="{StaticResource IconPlay}" Width="14" Height="14" />
            </Button>
            <Button Theme="{StaticResource JagToolButton}"
                    Command="{Binding StopCommand}"
                    ToolTip.Tip="Stop">
                <PathIcon Data="{StaticResource IconStop}" Width="14" Height="14" />
            </Button>
        </StackPanel>
    </Border>

</UserControl>

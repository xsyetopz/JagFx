<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JagFx.Desktop.ViewModels"
        xmlns:header="using:JagFx.Desktop.Views.Header"
        xmlns:inspector="using:JagFx.Desktop.Views.Inspector"
        xmlns:signalchain="using:JagFx.Desktop.Views.SignalChain"
        xmlns:footer="using:JagFx.Desktop.Views.Footer"
        x:Class="JagFx.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding WindowTitle}"
        Width="1400" Height="800"
        MinWidth="800" MinHeight="600"
        Background="{StaticResource SurfaceBaseBrush}"
        WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True">
        <!-- Header Bar -->
        <header:HeaderBar DockPanel.Dock="Top" DataContext="{Binding}" />

        <!-- Partials Footer -->
        <footer:PartialsFooter DockPanel.Dock="Bottom" DataContext="{Binding}" />

        <!-- Main content area: Inspector left, Matrix right -->
        <Grid ColumnDefinitions="160,*">
            <!-- Left: Inspector Panel -->
            <inspector:InspectorPanel Grid.Column="0" DataContext="{Binding}" />

            <!-- Right: Full-screen Signal Chain Matrix -->
            <signalchain:SignalChainPanel Grid.Column="1" DataContext="{Binding}" />
        </Grid>
    </DockPanel>

</Window>

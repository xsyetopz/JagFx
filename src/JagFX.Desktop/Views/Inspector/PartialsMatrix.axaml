<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JagFX.Desktop.ViewModels"
             xmlns:conv="using:JagFX.Desktop.Converters"
             x:Class="JagFX.Desktop.Views.Inspector.PartialsMatrix"
             x:DataType="vm:VoiceViewModel">

    <UserControl.Resources>
        <conv:RawToPercentConverter x:Key="RawToPercentConverter" />
        <conv:BoolToOpacityConverter x:Key="BoolToOpacity" />
    </UserControl.Resources>

    <Border Margin="0" Padding="0">
        <StackPanel Spacing="0">
            <!-- Section Header -->
            <Border Background="{StaticResource SurfaceCellHeaderBrush}" Padding="6,3"
                    BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="PARTIALS" FontSize="8" FontWeight="Bold"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <!-- Bank switch buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="1">
                        <ToggleButton Theme="{StaticResource JagVoiceToggle}"
                                      x:Name="Bank1Toggle"
                                      Content="1-5" IsChecked="True"
                                      FontSize="7" Padding="3,1" MinHeight="14" MinWidth="24" />
                        <ToggleButton Theme="{StaticResource JagVoiceToggle}"
                                      x:Name="Bank2Toggle"
                                      Content="6-10"
                                      FontSize="7" Padding="3,1" MinHeight="14" MinWidth="24" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Column headers -->
            <Border Padding="4,2" Background="{StaticResource SurfacePanelBrush}">
                <Grid ColumnDefinitions="18,*,50,40">
                    <TextBlock Grid.Column="0" Text="#" FontSize="7" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Grid.Column="1" Text="VOL" FontSize="7" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Grid.Column="2" Text="PITCH" FontSize="7" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Grid.Column="3" Text="DLY" FontSize="7" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- Partial rows -->
            <ItemsControl ItemsSource="{Binding VisiblePartials}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PartialViewModel">
                        <Border Padding="4,1" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,0.5"
                                Opacity="{Binding IsActive, Converter={StaticResource BoolToOpacity}}">
                            <Grid ColumnDefinitions="18,*,50,40">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsActive}"
                                          MinWidth="12" MinHeight="12"
                                          Padding="0" Margin="0" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                                    <NumericUpDown Theme="{StaticResource JagNumericStyle}"
                                                   Value="{Binding Amplitude, Converter={StaticResource RawToPercentConverter}}"
                                                   Minimum="0" Maximum="100"
                                                   MinHeight="16" FontSize="8"
                                                   FormatString="F1" />
                                    <TextBlock Text="%" FontSize="7" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2">
                                    <NumericUpDown Theme="{StaticResource JagNumericStyle}"
                                                   Value="{Binding PitchOffsetSemitones}"
                                                   Minimum="-128" Maximum="127"
                                                   MinHeight="16" FontSize="8" />
                                    <TextBlock Text="st" FontSize="7" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="2"
                                            HorizontalAlignment="Right">
                                    <NumericUpDown Theme="{StaticResource JagNumericStyle}"
                                                   Value="{Binding DelayMs}"
                                                   Minimum="0" Maximum="65535"
                                                   MinHeight="16" FontSize="8" />
                                    <TextBlock Text="ms" FontSize="7" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>

</UserControl>

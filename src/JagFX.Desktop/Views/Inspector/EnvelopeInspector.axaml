<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JagFx.Desktop.ViewModels"
             xmlns:insp="using:JagFx.Desktop.Views.Inspector"
             xmlns:conv="using:JagFx.Desktop.Converters"
             xmlns:controls="using:JagFx.Desktop.Controls"
             x:Class="JagFx.Desktop.Views.Inspector.EnvelopeInspector"
             x:DataType="vm:MainViewModel">

    <UserControl.Resources>
        <conv:RawToPercentConverter x:Key="RawToPercentConverter" />
    </UserControl.Resources>

    <Border IsVisible="{Binding SelectedEnvelope, Converter={x:Static ObjectConverters.IsNotNull}}">
        <StackPanel Spacing="0">
            <!-- Section Header -->
            <Border Background="{StaticResource SurfaceCellHeaderBrush}" Padding="6,3"
                    BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,1">
                <TextBlock FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextAccentBrush}"
                           Text="{Binding SelectedEnvelopeTitle, StringFormat='ENVELOPE: {0}'}" />
            </Border>

            <!-- Envelope start/end values -->
            <Border Padding="6,6">
                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                    <controls:KnobControl Value="{Binding SelectedEnvelope.StartValue, Converter={StaticResource RawToPercentConverter}, TargetNullValue=0, FallbackValue=0}"
                                          Minimum="-100" Maximum="100" Label="START" Step="0.5"
                                          FormatString="F1" Unit="%" Height="56" />
                    <controls:KnobControl Value="{Binding SelectedEnvelope.EndValue, Converter={StaticResource RawToPercentConverter}, TargetNullValue=0, FallbackValue=0}"
                                          Minimum="-100" Maximum="100" Label="END" Step="0.5"
                                          FormatString="F1" Unit="%" Height="56" />
                </StackPanel>
            </Border>

            <!-- Segments -->
            <ItemsControl ItemsSource="{Binding SelectedEnvelope.Segments}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SegmentViewModel">
                        <Border Padding="4,1" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,0.5">
                            <Grid ColumnDefinitions="16,*,*,18">
                                <TextBlock Grid.Column="0" Text="{Binding Index}" FontSize="9"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                                <controls:KnobControl Grid.Column="1"
                                                      Value="{Binding Duration, Converter={StaticResource RawToPercentConverter}, TargetNullValue=0, FallbackValue=0}"
                                                      Minimum="0" Maximum="100" Label="DUR" Step="0.5"
                                                      FormatString="F1" Unit="%" Height="50" />
                                <controls:KnobControl Grid.Column="2"
                                                      Value="{Binding TargetLevel, Converter={StaticResource RawToPercentConverter}, TargetNullValue=0, FallbackValue=0}"
                                                      Minimum="0" Maximum="100" Label="LVL" Step="0.5"
                                                      FormatString="F1" Unit="%" Height="50" />
                                <Button Grid.Column="3" Theme="{StaticResource JagToolButton}"
                                        Padding="2,0" MinWidth="14" MinHeight="14"
                                        Command="{Binding DataContext.SelectedEnvelope.RemoveSegmentCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <PathIcon Data="{StaticResource IconClose}" Width="8" Height="8"
                                              Foreground="{StaticResource TextMutedBrush}" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Theme="{StaticResource JagToolButton}" Margin="4,2"
                    HorizontalAlignment="Center"
                    Command="{Binding SelectedEnvelope.AddDefaultSegmentCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <PathIcon Data="{StaticResource IconPlus}" Width="8" Height="8"
                              Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="ADD" FontSize="9" Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>

</UserControl>

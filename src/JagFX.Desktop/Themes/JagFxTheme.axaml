<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Global dark background -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource SurfaceBaseBrush}" />
        <Setter Property="FontFamily" Value="Consolas, Monaco, Courier New, monospace" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Compact TextBlock defaults -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="Consolas, Monaco, Courier New, monospace" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Separator styling -->
    <Style Selector="Separator">
        <Setter Property="Background" Value="{DynamicResource BorderDefaultBrush}" />
        <Setter Property="Height" Value="1" />
    </Style>

    <!-- ScrollBar thin dark style -->
    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- NumericUpDown compact dark style (preserves Fluent template) -->
    <Style Selector="NumericUpDown">
        <Setter Property="Background" Value="{DynamicResource SurfaceInputBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Consolas, Monaco, Courier New, monospace" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Padding" Value="4,0" />
        <Setter Property="ShowButtonSpinner" Value="False" />
    </Style>

    <!-- Ensure inner TextBox text is visible and centered on dark background -->
    <Style Selector="NumericUpDown /template/ TextBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="2,0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Height" Value="20" />
    </Style>

    <!-- Strip Fluent chrome from inner TextBox border -->
    <Style Selector="NumericUpDown /template/ TextBox /template/ Border#PART_BorderElement">
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Force TextPresenter vertical centering -->
    <Style Selector="NumericUpDown /template/ TextBox /template/ TextPresenter#PART_TextPresenter">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Remove DataValidationErrors wrapper height -->
    <Style Selector="NumericUpDown /template/ DataValidationErrors">
        <Setter Property="MinHeight" Value="0" />
    </Style>

</Styles>

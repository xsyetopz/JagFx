<?xml version="1.0" encoding="UTF-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JagFx.Desktop.ViewModels"
             x:Class="JagFx.Desktop.Views.SignalChain.SignalChainPanel"
             x:DataType="vm:MainViewModel">
    <Border Background="{StaticResource SurfacePanelBrush}">
        <Grid x:Name="MatrixGrid"
              RowDefinitions="*,*,*"
              ColumnDefinitions="*,*,*,0"
              Margin="1" />
    </Border>
</UserControl>

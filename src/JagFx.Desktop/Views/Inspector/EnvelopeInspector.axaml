<?xml version="1.0" encoding="UTF-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:loc="using:JagFx.Desktop.Localization"
             xmlns:vm="using:JagFx.Desktop.ViewModels"
             xmlns:insp="using:JagFx.Desktop.Views.Inspector"
             xmlns:conv="using:JagFx.Desktop.Converters"
             xmlns:controls="using:JagFx.Desktop.Controls.Canvases"
             x:Class="JagFx.Desktop.Views.Inspector.EnvelopeInspector"
             x:DataType="vm:MainViewModel">
    <UserControl.Resources>
        <conv:RawToPercentConverter x:Key="RawToPercentConverter" />
        <conv:IntToDoubleConverter x:Key="IntToDoubleConverter" />
    </UserControl.Resources>
    <Border IsVisible="{Binding SelectedEnvelope, Converter={x:Static ObjectConverters.IsNotNull}}">
        <StackPanel Spacing="0">
            <!-- Section Header -->
            <Border Background="{StaticResource SurfaceCellHeaderBrush}"
                    Padding="6,3"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="0,1,0,1">
                <TextBlock FontSize="11"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextAccentBrush}"
                           Text="{Binding SelectedEnvelopeTitle}"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding SelectedEnvelopeTitle}" />
            </Border>
            <!-- Waveform selector -->
            <Border Padding="6,4">
                <StackPanel Orientation="Horizontal"
                            Spacing="2"
                            HorizontalAlignment="Center">
                    <ToggleButton Theme="{StaticResource JagCellToggle}"
                                  IsChecked="{Binding SelectedEnvelope.IsOffActive, Mode=OneWay}"
                                  Command="{Binding SelectedEnvelope.SetWaveformCommand}"
                                  CommandParameter="0"
                                  ToolTip.Tip="{loc:Tr TooltipWaveOff}">
                        <i:Icon Value="mdi-signal-off"
                                FontSize="15" />
                    </ToggleButton>
                    <ToggleButton Theme="{StaticResource JagCellToggle}"
                                  IsChecked="{Binding SelectedEnvelope.IsSquareActive, Mode=OneWay}"
                                  Command="{Binding SelectedEnvelope.SetWaveformCommand}"
                                  CommandParameter="1"
                                  ToolTip.Tip="{loc:Tr TooltipWaveSquare}">
                        <i:Icon Value="mdi-square-wave"
                                FontSize="15" />
                    </ToggleButton>
                    <ToggleButton Theme="{StaticResource JagCellToggle}"
                                  IsChecked="{Binding SelectedEnvelope.IsSineActive, Mode=OneWay}"
                                  Command="{Binding SelectedEnvelope.SetWaveformCommand}"
                                  CommandParameter="2"
                                  ToolTip.Tip="{loc:Tr TooltipWaveSine}">
                        <i:Icon Value="mdi-sine-wave"
                                FontSize="15" />
                    </ToggleButton>
                    <ToggleButton Theme="{StaticResource JagCellToggle}"
                                  IsChecked="{Binding SelectedEnvelope.IsSawActive, Mode=OneWay}"
                                  Command="{Binding SelectedEnvelope.SetWaveformCommand}"
                                  CommandParameter="3"
                                  ToolTip.Tip="{loc:Tr TooltipWaveSawtooth}">
                        <i:Icon Value="mdi-sawtooth-wave"
                                FontSize="15" />
                    </ToggleButton>
                    <ToggleButton Theme="{StaticResource JagCellToggle}"
                                  IsChecked="{Binding SelectedEnvelope.IsNoiseActive, Mode=OneWay}"
                                  Command="{Binding SelectedEnvelope.SetWaveformCommand}"
                                  CommandParameter="4"
                                  ToolTip.Tip="{loc:Tr TooltipWaveNoise}">
                        <i:Icon Value="mdi-waveform"
                                FontSize="15" />
                    </ToggleButton>
                </StackPanel>
            </Border>
            <!-- Envelope start/end values -->
            <Border Padding="6,6">
                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Center">
                    <controls:KnobControl Value="{Binding SelectedEnvelope.StartValue, Converter={StaticResource IntToDoubleConverter}, TargetNullValue=0, FallbackValue=0}"
                                          Minimum="{Binding StartEndMin}"
                                          Maximum="{Binding StartEndMax}"
                                          Label="{loc:TrUpper StartLabel}"
                                          Step="1"
                                          FormatString="F0"
                                          Unit="{Binding StartEndUnit}"
                                          Height="40" />
                    <controls:KnobControl Value="{Binding SelectedEnvelope.EndValue, Converter={StaticResource IntToDoubleConverter}, TargetNullValue=0, FallbackValue=0}"
                                          Minimum="{Binding StartEndMin}"
                                          Maximum="{Binding StartEndMax}"
                                          Label="{loc:TrUpper EndLabel}"
                                          Step="1"
                                          FormatString="F0"
                                          Unit="{Binding StartEndUnit}"
                                          Height="40" />
                </StackPanel>
            </Border>
            <Border Margin="4,2,4,2"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="0,0,0,1" />
            <!-- Segments -->
            <ItemsControl ItemsSource="{Binding SelectedEnvelope.Segments}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SegmentViewModel">
                        <Border Padding="4,1"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="0,0,0,0.5">
                            <Grid ColumnDefinitions="16,*,*,18">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Index}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                                <controls:KnobControl Grid.Column="1"
                                                      Value="{Binding Duration, Converter={StaticResource RawToPercentConverter}, TargetNullValue=0, FallbackValue=0}"
                                                      Minimum="0"
                                                      Maximum="100"
                                                      Label="{loc:TrUpper SegmentDurationLabel}"
                                                      Step="0.5"
                                                      FormatString="F1"
                                                      Unit="%"
                                                      Height="40" />
                                <controls:KnobControl Grid.Column="2"
                                                      Value="{Binding TargetLevel, Converter={StaticResource RawToPercentConverter}, TargetNullValue=0, FallbackValue=0}"
                                                      Minimum="0"
                                                      Maximum="100"
                                                      Label="{loc:TrUpper SegmentLevelLabel}"
                                                      Step="0.5"
                                                      FormatString="F1"
                                                      Unit="%"
                                                      Height="40" />
                                <Button Grid.Column="3"
                                        Theme="{StaticResource JagCellButton}"
                                        ToolTip.Tip="{loc:Tr MenuDeletePoint}"
                                        Command="{ReflectionBinding DataContext.SelectedEnvelope.RemoveSegmentCommand,&#xA;                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                <i:Icon Value="mdi-close"
                                            FontSize="15"
                                            Foreground="{StaticResource TextMutedBrush}" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Theme="{StaticResource JagCellButton}"
                    Margin="4,2"
                    Width="NaN"
                    HorizontalAlignment="Stretch"
                    ToolTip.Tip="{loc:Tr AddSegment}"
                    Command="{Binding SelectedEnvelope.AddDefaultSegmentCommand}">
                <i:Icon Value="mdi-plus"
                        FontSize="15" />
            </Button>
        </StackPanel>
    </Border>
</UserControl>

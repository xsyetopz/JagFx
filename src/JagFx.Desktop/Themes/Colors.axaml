<?xml version="1.0" encoding="UTF-8"?>
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
    <!-- Typography and density tokens -->
    <x:Double x:Key="FontSizeUiBase">11</x:Double>
    <x:Double x:Key="FontSizeUiSmall">11</x:Double>
    <x:Double x:Key="FontSizeUiCaption">10</x:Double>
    <Thickness x:Key="PaddingUiToolbar">7,4</Thickness>
    <Thickness x:Key="PaddingUiCompact">5,2</Thickness>
    <Thickness x:Key="PaddingUiInput">5,3</Thickness>
    <x:Double x:Key="HeightUiToolbar">28</x:Double>
    <x:Double x:Key="HeightUiCompact">24</x:Double>
    <x:Double x:Key="HeightUiInput">28</x:Double>
    <x:Double x:Key="HeightUiNumericInput">28</x:Double>
    <x:Double x:Key="WidthUiCompact">24</x:Double>
    <Thickness x:Key="PaddingUiNumericInput">4,3</Thickness>
    <!-- Base surface colors -->
    <Color x:Key="SurfaceBase">#1A1A1A</Color>
    <Color x:Key="SurfaceGraph">#000000</Color>
    <Color x:Key="SurfaceHeader">#333333</Color>
    <Color x:Key="SurfacePanel">#333333</Color>
    <Color x:Key="SurfaceCell">#333333</Color>
    <Color x:Key="SurfaceCellHeader">#4D4D4D</Color>
    <Color x:Key="SurfaceInput">#000000</Color>
    <Color x:Key="SurfaceFooter">#1A1A1A</Color>
    <!-- Border colors -->
    <Color x:Key="BorderDefault">#4D4D4D</Color>
    <Color x:Key="BorderSubtle">#4D4D4D</Color>
    <Color x:Key="BorderAccent">#009E73</Color>
    <!-- Text colors -->
    <Color x:Key="TextPrimary">#F5F5F5</Color>
    <Color x:Key="TextSecondary">#CCCCCC</Color>
    <Color x:Key="TextMuted">#999999</Color>
    <Color x:Key="TextButton">#F5F5F5</Color>
    <Color x:Key="TextAccent">#009E73</Color>
    <!-- Accent colors -->
    <Color x:Key="AccentPrimary">#009E73</Color>
    <Color x:Key="AccentSecondary">#0072B2</Color>
    <!-- Envelope line colors -->
    <Color x:Key="LineEnvelope">#F0E442</Color>
    <Color x:Key="LineFilter">#0072B2</Color>
    <!-- Breakpoint colors -->
    <Color x:Key="BreakpointFill">#F0E442</Color>
    <Color x:Key="BreakpointSelected">#F5F5F5</Color>
    <!-- Grid line color -->
    <Color x:Key="GridLine">#333333</Color>
    <Color x:Key="GridMidline">#666666</Color>
    <!-- Button colors -->
    <Color x:Key="ButtonDefault">#666666</Color>
    <Color x:Key="ButtonBorder">#808080</Color>
    <Color x:Key="ButtonHover">#808080</Color>
    <Color x:Key="ButtonActive">#4D4D4D</Color>
    <Color x:Key="ButtonActiveBorder">#009E73</Color>
    <!-- Voice strip active/inactive -->
    <Color x:Key="VoiceActive">#009E73</Color>
    <Color x:Key="VoiceInactive">#4D4D4D</Color>
    <!-- Voice button states -->
    <Color x:Key="VoiceInactiveBg">#4D4D4D</Color>
    <Color x:Key="VoiceInactiveText">#666666</Color>
    <Color x:Key="VoiceInactiveBorder">#4D4D4D</Color>
    <Color x:Key="VoiceEnabledBg">#4D4D4D</Color>
    <Color x:Key="VoiceEnabledBorder">#666666</Color>
    <!-- SolidColorBrushes for direct binding -->
    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBase}" />
    <SolidColorBrush x:Key="SurfaceGraphBrush" Color="{StaticResource SurfaceGraph}" />
    <SolidColorBrush x:Key="SurfaceHeaderBrush" Color="{StaticResource SurfaceHeader}" />
    <SolidColorBrush x:Key="SurfacePanelBrush" Color="{StaticResource SurfacePanel}" />
    <SolidColorBrush x:Key="SurfaceCellBrush" Color="{StaticResource SurfaceCell}" />
    <SolidColorBrush x:Key="SurfaceCellHeaderBrush" Color="{StaticResource SurfaceCellHeader}" />
    <SolidColorBrush x:Key="SurfaceInputBrush" Color="{StaticResource SurfaceInput}" />
    <SolidColorBrush x:Key="SurfaceFooterBrush" Color="{StaticResource SurfaceFooter}" />
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefault}" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />
    <SolidColorBrush x:Key="BorderAccentBrush" Color="{StaticResource BorderAccent}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="TextButtonBrush" Color="{StaticResource TextButton}" />
    <SolidColorBrush x:Key="TextAccentBrush" Color="{StaticResource TextAccent}" />
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimary}" />
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondary}" />
    <SolidColorBrush x:Key="LineEnvelopeBrush" Color="{StaticResource LineEnvelope}" />
    <SolidColorBrush x:Key="LineFilterBrush" Color="{StaticResource LineFilter}" />
    <SolidColorBrush x:Key="GridLineBrush" Color="{StaticResource GridLine}" />
    <SolidColorBrush x:Key="GridMidlineBrush" Color="{StaticResource GridMidline}" />
    <SolidColorBrush x:Key="ButtonDefaultBrush" Color="{StaticResource ButtonDefault}" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource ButtonBorder}" />
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="{StaticResource ButtonHover}" />
    <SolidColorBrush x:Key="ButtonActiveBrush" Color="{StaticResource ButtonActive}" />
    <SolidColorBrush x:Key="ButtonActiveBorderBrush" Color="{StaticResource ButtonActiveBorder}" />
    <SolidColorBrush x:Key="VoiceInactiveBgBrush" Color="{StaticResource VoiceInactiveBg}" />
    <SolidColorBrush x:Key="VoiceInactiveTextBrush" Color="{StaticResource VoiceInactiveText}" />
    <SolidColorBrush
        x:Key="VoiceInactiveBorderBrush"
        Color="{StaticResource VoiceInactiveBorder}"
    />
    <SolidColorBrush x:Key="VoiceEnabledBgBrush" Color="{StaticResource VoiceEnabledBg}" />
    <SolidColorBrush x:Key="VoiceEnabledBorderBrush" Color="{StaticResource VoiceEnabledBorder}" />
</ResourceDictionary>

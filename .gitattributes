# Auto-detect text files and normalize line endings
* text=auto

# Source code — force LF
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.axaml text eol=lf
*.xml text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.manifest text eol=lf

# Shell scripts
*.sh text eol=lf
Makefile text eol=lf

# Windows scripts
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files — no line ending conversion
*.synth binary
*.hex binary
*.png binary
*.ico binary
*.mp4 binary
*.dll binary
*.exe binary
*.zip binary
*.tar.gz binary
*.sample binary

{
  "name": "@xsyetopz/jagfx",
  "version": "2.4.1",
  "description": "JavaScript and TypeScript bindings for JagFx synth rendering.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "src"
  ],
  "scripts": {
    "test": "bun test test/index.test.mjs",
    "build:esm": "bun build ./src/index.ts --target=node --format=esm --packages=external --outfile=./dist/index.mjs",
    "build:cjs": "bun build ./src/index.ts --target=node --format=cjs --packages=external --outfile=./dist/index.cjs",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "bun run build:esm && bun run build:cjs && bun run build:types"
  },
  "keywords": [
    "jagfx",
    "osrs",
    "synth",
    "audio"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.23.1",
    "bun": ">=1.3.14"
  },
  "source": "./src/index.ts",
  "devDependencies": {
    "@types/node": "^26.0.1"
  }
}

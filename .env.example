# ─────────────────────────────────────────────────────────────────
# JagFx macOS notarization environment
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────

# ── Signing ──────────────────────────────────────────────────────

# Full name of your Developer ID Application certificate as it appears
# in Keychain Access (Applications > Certificates).
# Example: Developer ID Application: Jane Smith (AB12CD34EF)
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Your 10-character Apple Developer Team ID.
# Find it at: https://developer.apple.com/account → Membership Details
APPLE_TEAM_ID="AB12CD34EF"

# ── Notarization ─────────────────────────────────────────────────

# Name of the keychain profile created by:
#   xcrun notarytool store-credentials JagFx-Notarize \
#     --apple-id "you@example.com" \
#     --team-id  "AB12CD34EF" \
#     --password "xxxx-xxxx-xxxx-xxxx"   ← app-specific password from appleid.apple.com
#
# Run that command once to store credentials securely in the macOS Keychain.
# Then set this variable to the profile name you chose.
APPLE_NOTARIZE_PROFILE="JagFx-Notarize"
